{
  opts = {
    number = true;
    relativenumber = true;

    expandtab = true;
    shiftround = true;
    shiftwidth = 2;
    softtabstop = 2;
    tabstop = 2;

    scrolloff = 3;

    cursorcolumn = true;
    cursorline = true;

    clipboard = {
      providers.wl-copy.enable = true;
      register = [ "unnamedplus" "unnamed" ];
    };
  };
}
